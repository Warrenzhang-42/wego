{
  "$id": "route",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["id", "title", "spots"],
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "duration_minutes": { "type": "integer" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "category": { "type": "string", "description": "首页 Chip / 运营分类，与 migrations/005 中 category 列一致" },
    "cover_image": { "type": "string" },
    "thumbnail_image": { "type": "string", "description": "路线形状缩略图 URL 或 data URL" },
    "is_visible": { "type": "boolean", "default": true },
    "published_version": { "type": "integer", "minimum": 0 },
    "last_published_at": { "type": "string", "format": "date-time" },
    "total_distance_km": { "type": "number" },
    "spots": {
      "type": "array",
      "items": { "$ref": "spot.schema.json" }
    }
  }
}
