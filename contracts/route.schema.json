{
  "$id": "route",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["id", "title", "spots"],
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "duration_minutes": { "type": "integer" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "category": { "type": "string", "description": "展示类型可由前台根据标签等规则派生；非管理端配置项，库内列可保留兼容" },
    "city_adcode": { "type": "string", "description": "所在城市国标区划代码（地级市/直辖市，6 位），与 migrations/010 中 city_adcode 列一致；景点 WGS-84 坐标应落在该城市粗略边界内" },
    "cover_image": { "type": "string" },
    "thumbnail_image": { "type": "string", "description": "路线形状缩略图 URL 或 data URL" },
    "is_visible": { "type": "boolean", "default": true },
    "published_version": { "type": "integer", "minimum": 0 },
    "last_published_at": { "type": "string", "format": "date-time" },
    "total_distance_km": { "type": "number" },
    "spots": {
      "type": "array",
      "items": { "$ref": "spot.schema.json" }
    }
  }
}
