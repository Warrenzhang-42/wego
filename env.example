# 复制为 .env 后填写。勿将含密钥的 .env 提交到 git。

# 前端 / 种子脚本（已有）
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 可选：用 Node 直连 Postgres 执行 migrations/*.sql（如 npm run migrate:005）
# 来源：Supabase → Project Settings → Database → Connection string → URI
# 把 [YOUR-PASSWORD] 换成「数据库密码」（创建项目时设置），不是 API 密钥。
# DATABASE_URL=postgresql://postgres.xxxxx:[PASSWORD]@aws-0-xxx.pooler.supabase.com:6543/postgres
