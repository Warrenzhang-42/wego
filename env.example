# 复制为 .env 后填写。勿将含密钥的 .env 提交到 git。

# ---- Core ----
BACKEND_PORT=8787
# 默认监听 0.0.0.0（同 WiFi 设备可访问）；仅本机可设 BACKEND_HOST=127.0.0.1
DATABASE_URL=postgresql://wego:wego_pass_change_me@127.0.0.1:5432/wego

# ---- Auth ----
JWT_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=30d

# ---- Internal service-to-service ----
INTERNAL_API_TOKEN=change-me-internal
AGENT_BASE_URL=http://127.0.0.1:8000
BACKEND_API_URL=http://127.0.0.1:8787
AGENT_ACCESS_TOKEN=

# ---- Storage ----
UPLOAD_ROOT=./storage/images
PUBLIC_BASE_URL=http://127.0.0.1
