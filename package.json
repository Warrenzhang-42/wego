  "description": "",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "test": "node --test tests/unit/*.mjs tests/contracts/*.mjs",
    "dev": "vite --port 5173 --host 127.0.0.1",
    "dev:open": "vite --port 5173 --host 127.0.0.1 --open",
    "dev:lan": "vite --port 5173 --host 0.0.0.0",
    "dev:lan:open": "vite --port 5173 --host 0.0.0.0 --open",
    "admin:dev": "node admin-dev-server.js",
    "admin:dev:lan": "ADMIN_HOST=0.0.0.0 node admin-dev-server.js",
    "seed": "node data/scripts/seed-dashilan.js",
    "seed:dry": "DRY_RUN=true node data/scripts/seed-dashilan.js",
    "seed:beijing": "node data/scripts/seed-beijing-catalog.js",
    "seed:beijing:dry": "DRY_RUN=true node data/scripts/seed-beijing-catalog.js",
    "migrate:005": "node data/scripts/run-sql-migration.js server/migrations/005_routes_engagement.sql",
    "migrate:006": "node data/scripts/run-sql-migration.js server/migrations/006_route_ingestion_jobs.sql",
    "migrate:007": "node data/scripts/run-sql-migration.js server/migrations/007_route_drafts.sql",
    "migrate:010": "node data/scripts/run-sql-migration.js server/migrations/010_routes_city_adcode.sql",
    "migrate:011": "node data/scripts/run-sql-migration.js server/migrations/011_home_carousel_configs.sql",
    "migrate:013": "node data/scripts/run-sql-migration.js server/migrations/013_home_carousel_city_groups.sql",
    "migrate:route-upload": "npm run migrate:006 && npm run migrate:007",
    "deploy:route-ingest": "supabase functions deploy route-ingest",
    "backend:dev": "node -r dotenv/config backend/src/server.js",
    "backend:migrate": "node -r dotenv/config backend/scripts/migrate.js",
    "backend:seed": "node -r dotenv/config backend/scripts/seed.js"
  },
